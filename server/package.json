{
  "name": "facturacion-api",
  "version": "1.0.0",
  "description": "API backend para Facturación Electrónica",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "config:frontend": "node scripts/generateFrontendConfig.js",
    "postinstall": "node scripts/generateFrontendConfig.js",
    "dev": "node scripts/generateFrontendConfig.js && node --watch src/index.js",
    "start": "node scripts/generateFrontendConfig.js && node src/index.js",
    "frontend": "node scripts/generateFrontendConfig.js && node scripts/serveFrontend.js",
    "services:install": "powershell -ExecutionPolicy Bypass -File scripts/install-nssm-services.ps1",
    "services:uninstall": "powershell -ExecutionPolicy Bypass -File scripts/uninstall-nssm-services.ps1"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "mssql": "^11.0.1",
    "xmlbuilder2": "^4.0.3"
  }
}
